{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"strict": true,
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"types": ["node"]
	},
	"include": [
		"am2-globals.d.ts",
		"plugins/import/ui/web/assets/**/*.js",
		"plugins/web_interface/ui/assets/**/*.js",
		"playwright.config.ts",
