[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = """diff --git a/scripts/badguys_batch1_excluded/syntax_error.py b/scripts/badguys_batch1_excluded/syntax_error.py
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/scripts/badguys_batch1_excluded/syntax_error.py
@@ -0,0 +1,2 @@
+def oops(:
+    pass
"""
[[step]]
op = "RUN_RUNNER"
extra_args = [
    "--override",
  "compile_exclude=['scripts/badguys_batch1_excluded']",
  "${issue_id}",
  "badguys: compile exclude respected",
]
input_asset = "patch"

[[step]]
op = "READ_STEP_LOG"
