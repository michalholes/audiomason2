[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = 'diff --git a/scripts/badguys_batch1_excluded/syntax_error.py b/scripts/badguys_batch1_excluded/syntax_error.py\nnew file mode 100644\nindex 0000000..1111111\n--- /dev/null\n+++ b/scripts/badguys_batch1_excluded/syntax_error.py\n@@ -0,0 +1,2 @@\n+def oops(:\n+    pass\n'

[[step]]
op = "RUN_RUNNER"
extra_args = [
  "--test-mode",
  "--override",
  "compile_exclude=['scripts/badguys_batch1_excluded']",
  "${issue_id}",
  "badguys: compile exclude respected",
]
input_asset = "patch"

[[step]]
op = "READ_STEP_LOG"
