[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "zip"
kind = "patch_zip_manifest"

  [[asset.entry]]
  name = "patch_entry"
  content = """patch-wins
"""

  [[asset.entry]]
  name = "script_entry"
  content = """ctx.write_text("ignore_py", "py-wins\n")
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "zip"
