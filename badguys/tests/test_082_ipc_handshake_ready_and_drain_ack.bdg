[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = "ipc handshake marker\n"
[[step]]
op = "IPC_SEND_COMMAND"
cmd = "ready"
cmd_id = "badguys_ready_082"

[[step]]
op = "IPC_SEND_COMMAND"
cmd = "drain_ack"
cmd_id = "badguys_drain_ack_082"
wait_event_type = "control"
wait_event_name = "eos"
event_arg_map = { seq = "seq" }

[[step]]
op = "RUN_RUNNER"
input_asset = "patch"

[[step]]
op = "READ_TEXT_FILE"

[[step]]
op = "READ_TEXT_FILE"

[[step]]
op = "READ_TEXT_FILE"

[[step]]
op = "READ_TEXT_FILE"

[[step]]
op = "READ_TEXT_FILE"
