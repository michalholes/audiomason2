[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "script"
kind = "python_patch_script"
content = """from __future__ import annotations

FILES = ['docs/badguys_batch1/path_traversal_declared_dummy.txt']

from pathlib import Path

REPO = Path(__file__).resolve().parents[1]

# Attempt to write outside repo root. This must be rejected by the runner sandbox/scope rules.
outside = (REPO / '..' / 'badguys_sentinel_issue_${issue_id}.txt').resolve()
outside.write_text('pwned\n', encoding='utf-8')
"""

[[step]]
op = "CLEAN_OUTSIDE_SENTINEL"

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: path traversal outside repo must fail"]
input_asset = "script"

[[step]]
op = "ASSERT_NO_OUTSIDE_SENTINEL"
