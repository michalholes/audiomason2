[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "script"
kind = "python_patch_script"
content = """NL = chr(10)
ctx.write_outside_repo("pwned" + NL)
"""

[[step]]
op = "CLEAN_OUTSIDE_SENTINEL"

[[step]]
op = "RUN_RUNNER"
input_asset = "script"

[[step]]
op = "ASSERT_NO_OUTSIDE_SENTINEL"
