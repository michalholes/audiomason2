[meta]
makes_commit = true
is_guard = false

[[asset]]
id = "seed_patch"
kind = "git_patch_text"
content = 'diff --git a/src/audiomason/_badguys_seed_fail.py b/src/audiomason/_badguys_seed_fail.py\nnew file mode 100644\nindex 0000000..1111111\n--- /dev/null\n+++ b/src/audiomason/_badguys_seed_fail.py\n@@ -0,0 +1,1 @@\n+def oops(:\n'

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: seed run to create workspace"]
input_asset = "seed_patch"

[[step]]
op = "ASSERT_WORKSPACE_REPO_EXISTS"

[[step]]
op = "PREPARE_LATEST_BUNDLE_900"

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: apply latest bundle", "-l"]
