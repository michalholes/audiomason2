[meta]
makes_commit = true
is_guard = false

[[asset]]
id = "seed_patch"
kind = "git_patch_text"
content = """def oops(:
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "seed_patch"

[[step]]
op = "ASSERT_WORKSPACE_REPO_EXISTS"

[[step]]
op = "PREPARE_LATEST_BUNDLE_900"
stamp = "${now_stamp}"

[[step]]
op = "RUN_RUNNER"
