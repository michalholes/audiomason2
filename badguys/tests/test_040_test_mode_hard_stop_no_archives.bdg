[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = """diff --git a/docs/badguys_batch1/test_mode_hard_stop_marker.txt b/docs/badguys_batch1/test_mode_hard_stop_marker.txt
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/docs/badguys_batch1/test_mode_hard_stop_marker.txt
@@ -0,0 +1,1 @@
+marker
"""
[[step]]
op = "DELETE_PATCHED_ZIP"

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: test-mode hard stop"]
input_asset = "patch"

[[step]]
op = "ASSERT_NO_WORKSPACE_AND_NO_ARCHIVES"
