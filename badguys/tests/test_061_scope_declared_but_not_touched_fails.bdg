[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "python_patch_script"
content = "from __future__ import annotations\n\nFILES = ['docs/badguys_batch1/declared_untouched.txt', 'docs/badguys_batch1/scope_touched.txt']\n\nfrom pathlib import Path\n\nREPO = Path(__file__).resolve().parents[1]\n\n(REPO / 'docs/badguys_batch1/scope_touched.txt').parent.mkdir(parents=True, exist_ok=True)\n(REPO / 'docs/badguys_batch1/scope_touched.txt').write_text('touched\\\\n', encoding='utf-8')\n# declared_untouched.txt is declared but intentionally not touched\n"

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: scope declared but not touched fails"]
input_asset = "patch"
