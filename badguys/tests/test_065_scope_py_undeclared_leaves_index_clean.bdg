[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "python_patch_script"
content = """ctx.write_text("declared", "declared\n")
ctx.write_text("undeclared", "undeclared\n")
"""

[[step]]
op = "GIT_STATUS_PORCELAIN"

[[step]]
op = "RUN_RUNNER"
input_asset = "patch"

[[step]]
op = "GIT_STATUS_PORCELAIN"
