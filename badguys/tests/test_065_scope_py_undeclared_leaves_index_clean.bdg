[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "python_patch_script"
content = "from __future__ import annotations\n\nFILES = ['docs/badguys_batch1/scope_declared_index_clean.txt']\n\nfrom pathlib import Path\n\nREPO = Path(__file__).resolve().parents[1]\n\n(REPO / 'docs/badguys_batch1/scope_declared_index_clean.txt').parent.mkdir(parents=True, exist_ok=True)\n(REPO / 'docs/badguys_batch1/scope_declared_index_clean.txt').write_text('declared\\\\n', encoding='utf-8')\n(REPO / 'docs/badguys_batch1/scope_undeclared_index_clean.txt').write_text('undeclared\\\\n', encoding='utf-8')\n"

[[step]]
op = "GIT_STATUS_PORCELAIN"

[[step]]
op = "RUN_RUNNER"
extra_args = ["", "${issue_id}", "badguys: scope undeclared leaves live tree unchanged"]
input_asset = "patch"

[[step]]
op = "GIT_STATUS_PORCELAIN"
