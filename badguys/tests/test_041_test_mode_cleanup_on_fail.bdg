[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = """diff --git a/scripts/badguys_batch1_compile_fail.py b/scripts/badguys_batch1_compile_fail.py
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/scripts/badguys_batch1_compile_fail.py
@@ -0,0 +1,2 @@
+def oops(:
+    pass
"""
[[step]]
op = "DELETE_PATCHED_ZIP"

[[step]]
op = "RUN_RUNNER"
extra_args = ["", "${issue_id}", "badguys: test-mode cleanup on fail"]
input_asset = "patch"

[[step]]
op = "ASSERT_NO_WORKSPACE_AND_NO_ARCHIVES"
