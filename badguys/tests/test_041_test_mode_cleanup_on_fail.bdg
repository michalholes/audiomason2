[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "git_patch_text"
content = 'diff --git a/scripts/badguys_batch1_compile_fail.py b/scripts/badguys_batch1_compile_fail.py\nnew file mode 100644\nindex 0000000..1111111\n--- /dev/null\n+++ b/scripts/badguys_batch1_compile_fail.py\n@@ -0,0 +1,2 @@\n+def oops(:\n+    pass\n'

[[step]]
op = "DELETE_PATCHED_ZIP"

[[step]]
op = "RUN_RUNNER"
extra_args = ["--test-mode", "${issue_id}", "badguys: test-mode cleanup on fail"]
input_asset = "patch"

[[step]]
op = "ASSERT_NO_WORKSPACE_AND_NO_ARCHIVES"
