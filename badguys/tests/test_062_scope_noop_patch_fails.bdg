[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "patch"
kind = "python_patch_script"
content = "from __future__ import annotations\n\nFILES = ['docs/badguys_batch1/noop.txt']\n\nfrom pathlib import Path\n\nREPO = Path(__file__).resolve().parents[1]\n\n# Intentionally do nothing.\n"

[[step]]
op = "RUN_RUNNER"
extra_args = ["${issue_id}", "badguys: noop patch fails"]
input_asset = "patch"
