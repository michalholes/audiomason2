[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "script"
kind = "python_patch_script"
content = """text = ctx.path("protected").read_text(encoding="utf-8")
ctx.write_text(
    "protected",
    text.replace('\"enabled\": true', '\"enabled\": false', 1),
)
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "script"
