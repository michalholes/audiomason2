[meta]
makes_commit = false
is_guard = false

[[asset]]
id = "bundle"
kind = "patch_zip_manifest"

  [[asset.entry]]
  name = "inner.patch"
  content = """diff --git a/src/test.py b/src/test.py
new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/src/test.py
@@ -0,0 +1,1 @@
+oops = )
"""
[[step]]
op = "RUN_RUNNER"
extra_args = ["-g", "", "${issue_id}", "badguys: -g continues after gate fail (compile)"]
input_asset = "bundle"

[[step]]
op = "READ_STEP_LOG"
