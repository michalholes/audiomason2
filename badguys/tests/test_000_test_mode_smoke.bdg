[meta]
makes_commit = false
is_guard = true

[[asset]]
id = "smoke_patch"
kind = "git_patch_text"
content = """diff --git a/badguys/tmp/test_mode_smoke_marker.txt b/badguys/tmp/test_mode_smoke_marker.txt
new file mode 100644
--- /dev/null
+++ b/badguys/tmp/test_mode_smoke_marker.txt
@@
+badguys test-mode smoke
"""

[[step]]
op = "RUN_RUNNER"
input_asset = "smoke_patch"
extra_args = ["", "${issue_id}", "badguys: test-mode smoke"]
